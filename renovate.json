{
  "configMigration": true,
  "dependencyDashboard": true,
  "extends": ["config:recommended"],
  "automerge": true,
  "major": {
    "automerge": false
  },
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true
  },
  "labels": ["type: dependencies", "renovate"],
  "packageRules": [
    {
      "matchPackageNames": ["/eslint/", "globals"],
      "groupName": "eslint"
    }
  ]
}
